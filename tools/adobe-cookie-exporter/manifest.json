{
  "manifest_version": 3,
  "name": "Adobe Cookie Exporter",
  "description": "Export Adobe/Firefly cookies for GPT2Image Pro direct mode import.",
  "version": "1.0.0",
  "incognito": "split",
  "permissions": [
    "cookies",
    "downloads",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.adobe.com/*"
  ],
  "action": {
    "default_title": "Adobe Cookie Exporter",
    "default_popup": "popup.html"
  }
}
