# Copy to .env before running docker compose.

# Image tags
GPT2IMAGE_ENV_FILE=.env
GPT2IMAGE_IMAGE_TAG=latest

# Public URL
WEB_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GPT2IMAGE
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32

# Database used by docker-compose.yml
POSTGRES_DB=gpt2image
POSTGRES_USER=gpt2image
POSTGRES_PASSWORD=replace-with-a-strong-password

# Local storage inside the web container
LOCAL_STORAGE_PATH=/app/storage
NEXT_PUBLIC_AVATARS_BUCKET_NAME=avatars
NEXT_PUBLIC_GENERATIONS_BUCKET_NAME=generations
GPT2IMAGE_BOOTSTRAP_CREDENTIALS_PATH=/app/.gpt2image/super-admin-credentials.txt

# Default private deployment mode
SELF_USE_MODE_ENABLED=true
INTERNAL_JOB_SCHEDULER_ENABLED=true

# ChatGPT Web sidecar
CHATGPT_WEB_PROXY_URL=http://chatgpt-web-proxy:3021
CHATGPT_WEB_PROXY_SECRET=replace-with-sidecar-secret
CHATGPT_WEB_PROXY_PROFILE=chrome_146
CHATGPT_WEB_PROXY_TIMEOUT_SECONDS=300
CHATGPT_WEB_PROXY_MAX_BODY_MB=64
CHATGPT_WEB_UPSTREAM_PROXY_URL=

# Optional payment, mail, moderation and upstream settings can be configured
# in the admin UI after first startup, or added here when you need env fallback.
PAYMENT_PROVIDER=none
NEXT_PUBLIC_PAYMENT_PROVIDER=none
EMAIL_PROVIDER=
CONTENT_MODERATION_ENABLED=false

# Optional Sub2API backend pool sync.
# Prefer configuring sync tasks in the admin UI after startup. These values are
# only env fallbacks; changing this file requires `docker compose up -d`, not a rebuild.
SUB2API_POSTGRES_URL=
SUB2API_POSTGRES_SYNC_LIMIT=100
