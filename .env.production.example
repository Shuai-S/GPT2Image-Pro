# ============================================
# GPT2Image-Pro production template (superapi deployment)
# ============================================
# Copy this file to your real environment file and replace placeholders.
# Never commit real secrets such as SMTP_PASS, EPAY_KEY, PLATFORM_API_KEY,
# DATABASE_URL password, or BETTER_AUTH_SECRET.

# App
NEXT_PUBLIC_APP_URL=https://gpt2image.superapi.buzz
NEXT_PUBLIC_ADMIN_URL=http://localhost:3304
NEXT_PUBLIC_APP_NAME=GPT2IMAGE
BETTER_AUTH_URL=https://gpt2image.superapi.buzz
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32

# Database
DATABASE_URL=postgresql://postgres:<database-password>@localhost:5433/gpt2image

# OAuth placeholders
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mail: Aliyun Enterprise SMTP
EMAIL_PROVIDER=smtp
EMAIL_FROM="GPT2IMAGE <admin@superapi.buzz>"
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=admin@superapi.buzz
SMTP_PASS=<smtp-password-or-app-password>

# Payment: Epay
PAYMENT_PROVIDER=epay
NEXT_PUBLIC_PAYMENT_PROVIDER=epay
EPAY_API_URL=https://inv.foxnio.com/xpay/epay
EPAY_PID=10030
EPAY_KEY=<epay-merchant-key>
EPAY_NOTIFY_URL=https://3d22e3fd-ec68-48d1-a495-11421b932548.superapi.buzz/api/webhooks/epay
EPAY_DEFAULT_PAYMENT_TYPE=alipay
NEXT_PUBLIC_EPAY_DEFAULT_PAYMENT_TYPE=alipay

# Platform image generation via NewAPI-compatible endpoint
PLATFORM_API_BASE_URL=http://<newapi-internal-host>:3000/v1
PLATFORM_API_KEY=<newapi-api-key>
PLATFORM_IMAGE_MODEL=gpt-image-1
CREDITS_PER_IMAGE=1

# Content moderation: Aliyun first, OpenAI fallback
CONTENT_MODERATION_ENABLED=true
CONTENT_MODERATION_PROVIDER=auto
CONTENT_MODERATION_FAIL_CLOSED=true
ALIYUN_MODERATION_ACCESS_KEY_ID=<aliyun-access-key-id>
ALIYUN_MODERATION_ACCESS_KEY_SECRET=<aliyun-access-key-secret>
ALIYUN_MODERATION_REGION_ID=cn-shanghai
ALIYUN_MODERATION_TEXT_REGION_ID=ap-southeast-1
ALIYUN_MODERATION_TEXT_ENDPOINT=green-cip.ap-southeast-1.aliyuncs.com
ALIYUN_MODERATION_TEXT_SERVICE=ugc_moderation_byllm_cb
ALIYUN_MODERATION_IMAGE_REGION_ID=ap-southeast-1
ALIYUN_MODERATION_IMAGE_ENDPOINT=green-cip.ap-southeast-1.aliyuncs.com
ALIYUN_MODERATION_IMAGE_SERVICE=baselineCheck_cb
ALIYUN_MODERATION_TEXT_APP_ID=<aliyun-text-agent-app-id>
ALIYUN_MODERATION_IMAGE_APP_ID=<aliyun-image-agent-app-id>
ALIYUN_MODERATION_PUBLIC_BASE_URL=<public-image-base-url>
OPENAI_MODERATION_API_KEY=<openai-moderation-api-key>
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Storage fallback
LOCAL_STORAGE_PATH=/root/GPT2Image-Pro/storage
NEXT_PUBLIC_AVATARS_BUCKET_NAME=avatars
NEXT_PUBLIC_GENERATIONS_BUCKET_NAME=generations

# Inngest local mode
INNGEST_DEV=1
