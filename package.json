{
  "name": "gpt2image-pro",
  "version": "0.7.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "performance:assets": "node scripts/check-next-client-budgets.mjs",
    "dev:web": "turbo dev --filter=@repo/web",
    "build:web": "turbo build --filter=@repo/web",
    "db:generate": "pnpm --filter @repo/database db:generate",
    "db:migrate": "pnpm --filter @repo/database db:migrate",
    "db:push": "pnpm --filter @repo/database db:push",
    "db:studio": "pnpm --filter @repo/database db:studio"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  },
  "engines": {
    "node": ">=22 <25",
    "pnpm": "10.27.0"
  },
  "packageManager": "pnpm@10.27.0",
  "license": "AGPL-3.0-only"
}
