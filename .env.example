# ============================================
# GPT2Image-Pro 环境变量配置
# ============================================
# 复制此文件为 .env.local 并填写实际值
# cp .env.example .env.local
#
# 快速开始 (开发环境):
# 1. 数据库: 使用本地 PostgreSQL 或 Neon
# 2. 认证:   配置 GitHub/Google OAuth (可选，可用邮箱登录)
# 3. 后端:   在后台账号池配置 API/Web/Codex 账号
# 4. 启动:   pnpm dev
#

# ============================================
# 应用配置
# ============================================
# 应用 URL【必配】用于 OAuth 回调与 API 请求,须为站点对外访问地址(如 https://your-domain)。
# 注意:这是构建期变量(打包进前端),改它需要重新构建镜像;且应与 BETTER_AUTH_URL 保持一致。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 应用名称 (显示在邮件、通知等)
NEXT_PUBLIC_APP_NAME=GPT2IMAGE

# 默认用户积分 (新用户注册时赠送)
# DEFAULT_USER_CREDITS=100

# ============================================
# 数据库配置 (PostgreSQL)
# ============================================
# 本地 Docker PostgreSQL 示例:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/gpt2image

# Neon Serverless PostgreSQL 示例 (注意: 使用非 pooler 端点以支持事务):
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=postgresql://postgres:password@localhost:5432/gpt2image

# ============================================
# Better Auth 配置【部署前必配,否则包括超管在内所有人都登录不进去】
# ============================================
# 认证密钥 (用于签名会话 Cookie)。生成方法: openssl rand -base64 32
# 【必配】请改成随机长串,切勿沿用示例值。
BETTER_AUTH_SECRET=your-super-secret-key-change-in-production

# 认证 URL【必配】须为站点对外访问地址,与浏览器实际访问的域名/协议完全一致
# (通常与 NEXT_PUBLIC_APP_URL 相同,如 https://your-domain);不一致会导致登录回调/Cookie 域不匹配。
BETTER_AUTH_URL=http://localhost:3000

# 额外信任来源(可选,逗号分隔)。反代/多域名部署时,把实际访问域名加进来,否则
# 浏览器 Origin 与受信来源不匹配会导致登录失败。BETTER_AUTH_URL 已自动包含,无需重复。
# 例:BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com,https://www.example.com
BETTER_AUTH_TRUSTED_ORIGINS=

# ============================================
# GitHub OAuth 配置
# ============================================
# 1. 访问 https://github.com/settings/developers
# 2. 点击 "New OAuth App"
# 3. 填写:
#    - Application name: GPT2IMAGE (或你的应用名)
#    - Homepage URL: http://localhost:3000
#    - Authorization callback URL: http://localhost:3000/api/auth/callback/github
# 4. 获取 Client ID 和 Client Secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# Google OAuth 配置
# ============================================
# 1. 访问 https://console.cloud.google.com/apis/credentials
# 2. 创建项目 (如果还没有)
# 3. 点击 "Create Credentials" -> "OAuth client ID"
# 4. 选择 "Web application"
# 5. 添加:
#    - Authorized JavaScript origins: http://localhost:3000
#    - Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
# 6. 获取 Client ID 和 Client Secret

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# 支付配置
# ============================================
# 可选: creem 或 epay。默认 creem。
PAYMENT_PROVIDER=creem
NEXT_PUBLIC_PAYMENT_PROVIDER=creem

# ============================================
# Creem 支付配置
# ============================================
# 1. 访问 https://dashboard.creem.io 获取 API Key
# 2. 创建 Webhook 并获取 Secret

CREEM_API_KEY=creem_api_key_xxx
CREEM_WEBHOOK_SECRET=creem_webhook_secret_xxx

# Creem 价格 ID (在 Creem Dashboard -> Products 中创建)
# 可选: 如果不配置，对应的计划将不可用
NEXT_PUBLIC_CREEM_PRICE_STARTER_MONTHLY=price_xxx
NEXT_PUBLIC_CREEM_PRICE_STARTER_YEARLY=price_xxx
NEXT_PUBLIC_CREEM_PRICE_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_CREEM_PRICE_PRO_YEARLY=price_xxx
NEXT_PUBLIC_CREEM_PRICE_ULTRA_MONTHLY=price_xxx
NEXT_PUBLIC_CREEM_PRICE_ULTRA_YEARLY=price_xxx
NEXT_PUBLIC_CREEM_PRICE_ENTERPRISE_MONTHLY=price_xxx
NEXT_PUBLIC_CREEM_PRICE_ENTERPRISE_YEARLY=price_xxx

# ============================================
# 易支付配置 (PAYMENT_PROVIDER=epay 时启用)
# ============================================
# 易支付网关地址，例如 https://pay.example.com
EPAY_API_URL=https://pay.example.com
# 商户 ID 和商户密钥
EPAY_PID=1000
EPAY_KEY=your-epay-secret-key
# 异步通知地址；留空则使用 NEXT_PUBLIC_APP_URL/api/webhooks/epay
EPAY_NOTIFY_URL=
# 默认支付方式: alipay / wxpay / qqpay 等，按易支付网关支持项填写
EPAY_DEFAULT_PAYMENT_TYPE=alipay
NEXT_PUBLIC_EPAY_DEFAULT_PAYMENT_TYPE=alipay

# ============================================
# 邮件服务配置 (SMTP / Resend)
# ============================================
# 发件人地址 (格式: "Name <email@domain.com>")
EMAIL_FROM="GPT2IMAGE <noreply@your-domain.com>"

# 用户新建工单或追加回复时通知管理员的邮箱；留空则不发送
SUPPORT_TICKET_NOTIFICATION_EMAIL=

# 可选: smtp 或 resend。留空时优先使用完整 SMTP 配置，否则使用 Resend。
EMAIL_PROVIDER=smtp

# SMTP 示例 (阿里企业邮箱 465/SSL 等)
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=admin@your-domain.com
SMTP_PASS=your-smtp-password-or-app-password

# Resend 示例:
# 1. 访问 https://resend.com
# 2. 创建 API Key
# 3. 配置发件域名 (用于生产环境)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your-resend-api-key

# ============================================
# 存储配置 (S3 兼容: AWS S3 / Cloudflare R2 / MinIO)
# ============================================
# GPT2Image-Pro 使用对象存储保存用户上传的文件和生成的图片
#
# 本地开发可选，不配置则文件上传功能不可用
#
# Cloudflare R2 示例:
# STORAGE_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# STORAGE_REGION=auto

# AWS S3 示例:
# STORAGE_ENDPOINT=https://s3.us-east-1.amazonaws.com
# STORAGE_REGION=us-east-1

STORAGE_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=your-access-key-id
STORAGE_SECRET_ACCESS_KEY=your-secret-access-key

# 头像存储桶名称 (需要预先在存储服务中创建)
NEXT_PUBLIC_AVATARS_BUCKET_NAME=avatars

# 生成图片存储桶名称
NEXT_PUBLIC_GENERATIONS_BUCKET_NAME=generations

# 本地存储路径 (开发环境使用，不配置 S3 时的 fallback)
# LOCAL_STORAGE_PATH=./storage

# Credits cost per image generation
CREDITS_PER_IMAGE=1

# 整站同时执行的生图任务硬上限；后台「系统设置 > 模型」可覆盖。
IMAGE_GENERATION_GLOBAL_CONCURRENCY=500

# ============================================
# 内容安全审核配置 (可选)
# ============================================
# 默认开启；auto 模式下优先使用阿里云，其次 OpenAI。
CONTENT_MODERATION_ENABLED=true
# 可选: auto / aliyun / openai / none。默认 auto。
CONTENT_MODERATION_PROVIDER=auto
# 审核服务异常时是否阻断生成。默认 true 为 fail-closed；未配置任何审核服务时仍会跳过。
CONTENT_MODERATION_FAIL_CLOSED=true

# 阿里云内容安全增强版，多模态审核。
# AccessKey 建议使用最小权限 RAM 子账号。
ALIYUN_MODERATION_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_MODERATION_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
# 文本审核出海多语言版 TextModerationPlus；配置后文生图优先使用它。
ALIYUN_MODERATION_TEXT_REGION_ID=ap-southeast-1
ALIYUN_MODERATION_TEXT_ENDPOINT=green-cip.ap-southeast-1.aliyuncs.com
ALIYUN_MODERATION_TEXT_SERVICE=ugc_moderation_byllm_cb
# 图片审核出海版 ImageModeration；配置后图生图优先使用它。
ALIYUN_MODERATION_IMAGE_REGION_ID=ap-southeast-1
ALIYUN_MODERATION_IMAGE_ENDPOINT=green-cip.ap-southeast-1.aliyuncs.com
ALIYUN_MODERATION_IMAGE_SERVICE=baselineCheck_cb
# 图生图审查参考图的公网访问域名；本地存储时用于拼接 /api/storage/...。
# CONTENT_MODERATION_PUBLIC_BASE_URL=https://your-public-image-domain.example

# OpenAI moderation fallback。
OPENAI_MODERATION_API_KEY=sk-your-openai-moderation-api-key
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Sub2API 账号池同步（可在后台系统设置中覆盖）
# SUB2API_POSTGRES_URL=postgresql://user:password@localhost:5432/sub2api
# SUB2API_POSTGRES_SYNC_LIMIT=100

# Google Analytics (可选)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# Rate Limiting 配置 (Upstash Redis) - 可选
# ============================================
# 用于 API 限流保护，防止滥用
# 未配置时将跳过限流检查
#
# 1. 访问 https://upstash.com
# 2. 创建 Redis 数据库
# 3. 获取 REST URL 和 Token

# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx
# RATE_LIMIT_GLOBAL_REQUESTS_PER_MINUTE=100
# RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5
# RATE_LIMIT_AI_REQUESTS_PER_MINUTE=20
# RATE_LIMIT_PAYMENT_REQUESTS_PER_MINUTE=10
# RATE_LIMIT_UPLOAD_REQUESTS_PER_MINUTE=30
# RATE_LIMIT_STRICT_REQUESTS_PER_MINUTE=3

# ============================================
# 日志服务配置 (Axiom) - 可选
# ============================================
# 用于结构化日志收集和查询
# 未配置时将使用 console 输出
#
# 1. 访问 https://axiom.co
# 2. 创建数据集 (Dataset)
# 3. 获取 API Token

# AXIOM_TOKEN=xaat-xxx
# AXIOM_DATASET=gpt2image

# ============================================
# 错误监控配置 (Sentry) - 可选
# ============================================
# 用于错误追踪和性能监控
# 未配置时将使用 console 输出错误
#
# 1. 访问 https://sentry.io
# 2. 创建项目 (选择 Next.js)
# 3. 获取 DSN

# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=sntrys_xxx
