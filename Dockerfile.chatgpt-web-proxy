FROM golang:1.24-alpine AS builder

WORKDIR /src

COPY services/chatgpt-web-proxy/go.mod ./
RUN go mod download

COPY services/chatgpt-web-proxy/ ./
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/chatgpt-web-proxy .

FROM alpine:3.22 AS runner

RUN addgroup -S app && adduser -S app -G app

COPY --from=builder /out/chatgpt-web-proxy /usr/local/bin/chatgpt-web-proxy

USER app
EXPOSE 3021

ENV CHATGPT_WEB_PROXY_BIND=":3021"
ENV CHATGPT_WEB_PROXY_PROFILE="chrome_146"

ENTRYPOINT ["chatgpt-web-proxy"]
