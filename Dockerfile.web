# 基础镜像用 glibc(debian slim)而非 alpine(musl):onnxruntime-node 只有 glibc 预编译,
# musl 上 ISNet 抠图(PSD 导出 / 透明回退)会加载失败;glibc 下 sharp/onnxruntime 预编译均可用。
FROM node:22-slim AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack prepare pnpm@10.27.0 --activate

# --- Prune monorepo for web app ---
FROM base AS pruner
WORKDIR /app
RUN pnpm add -g turbo@2.9.18
COPY . .
RUN turbo prune @repo/web --docker

# --- Install dependencies ---
FROM base AS deps
WORKDIR /app
COPY --from=pruner /app/out/json/ .
RUN pnpm install --frozen-lockfile

# --- Database migrator ---
FROM deps AS migrator
WORKDIR /app
COPY --from=pruner /app/out/full/ .
COPY tsconfig.base.json ./tsconfig.base.json
ENV NODE_ENV=production
CMD ["pnpm", "--dir", "packages/database", "db:migrate"]

# --- Build ---
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/ .
COPY --from=pruner /app/out/full/ .
COPY tsconfig.base.json ./tsconfig.base.json
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ARG NEXT_PUBLIC_APP_URL=http://localhost:3000
ARG NEXT_PUBLIC_APP_NAME=GPT2IMAGE
ARG NEXT_PUBLIC_PAYMENT_PROVIDER=none
ARG NEXT_PUBLIC_GENERATIONS_BUCKET_NAME=generations
ARG NEXT_PUBLIC_AVATARS_BUCKET_NAME=avatars
ARG NEXT_PUBLIC_ASSET_PREFIX=
ARG NEXT_PUBLIC_GA_ID=
ARG NEXT_PUBLIC_SENTRY_DSN=
ARG DATABASE_URL=postgresql://gpt2image:gpt2image@localhost:5432/gpt2image
ARG BETTER_AUTH_SECRET=build-time-placeholder-secret-not-for-runtime
ARG BETTER_AUTH_URL=http://localhost:3000
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_APP_NAME=$NEXT_PUBLIC_APP_NAME
ENV NEXT_PUBLIC_PAYMENT_PROVIDER=$NEXT_PUBLIC_PAYMENT_PROVIDER
ENV NEXT_PUBLIC_GENERATIONS_BUCKET_NAME=$NEXT_PUBLIC_GENERATIONS_BUCKET_NAME
ENV NEXT_PUBLIC_AVATARS_BUCKET_NAME=$NEXT_PUBLIC_AVATARS_BUCKET_NAME
ENV NEXT_PUBLIC_ASSET_PREFIX=$NEXT_PUBLIC_ASSET_PREFIX
ENV NEXT_PUBLIC_GA_ID=$NEXT_PUBLIC_GA_ID
ENV NEXT_PUBLIC_SENTRY_DSN=$NEXT_PUBLIC_SENTRY_DSN
ENV DATABASE_URL=$DATABASE_URL
ENV BETTER_AUTH_SECRET=$BETTER_AUTH_SECRET
ENV BETTER_AUTH_URL=$BETTER_AUTH_URL
# Docker 构建阶段没有运行中的 Postgres；运行时配置在此阶段只读环境变量，
# 避免静态预渲染 /_not-found 时连接 build-time 占位 DATABASE_URL。
ENV GPT2IMAGE_SKIP_RUNTIME_SETTINGS_DB=1
RUN pnpm turbo build --filter=@repo/web

# --- Runner ---
FROM node:22-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV LOCAL_STORAGE_PATH=/app/storage
ENV NEXT_PUBLIC_GENERATIONS_BUCKET_NAME=generations
ENV NEXT_PUBLIC_AVATARS_BUCKET_NAME=avatars
# ISNet 模型在 standalone 的 apps/web/models 下;容器 cwd=/app(CMD 跑 apps/web/server.js),
# 不显式指定的话 matte.ts 会按 cwd/models 找不到,故指向实际路径。
ENV ISNET_MODEL_PATH=/app/apps/web/models/isnet.onnx

RUN groupadd --system --gid 1001 nodejs && \
    useradd --system --uid 1001 --gid nodejs nextjs

# libonnxruntime.so.1 与 ISNet 模型已由 next.config.mjs 的 outputFileTracingIncludes
# 显式 trace 进 standalone(裸机与 Docker 共用同一机制),无需再从 builder 手工补拷。
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY scripts/docker-native-runtime-smoke.cjs ./docker-native-runtime-smoke.cjs
COPY scripts/docker-web-entrypoint.cjs /usr/local/bin/gpt2image-web-entrypoint.cjs

# standalone 保留 pnpm 虚拟仓库而不保留根层依赖软链；只给当前冒烟命令指定
# 模块目录，既确保从最终镜像解析依赖，也不改变应用运行时的模块查找边界。
RUN NODE_PATH=/app/node_modules/.pnpm/node_modules \
    node ./docker-native-runtime-smoke.cjs && \
    rm ./docker-native-runtime-smoke.cjs

RUN mkdir -p /app/storage /app/.gpt2image /app/apps/web/.next/cache && \
    chown -R nextjs:nodejs /app/storage /app/.gpt2image /app/apps/web/.next

EXPOSE 3000
ENV HOSTNAME="0.0.0.0"
ENV PORT=3000
ENV GPT2IMAGE_BOOTSTRAP_CREDENTIALS_PATH=/app/.gpt2image/super-admin-credentials.txt

# entrypoint 先以 root 修正 bind mount 权限，再 setuid/setgid 到 nextjs。
ENTRYPOINT ["node", "/usr/local/bin/gpt2image-web-entrypoint.cjs"]
CMD ["node", "apps/web/server.js"]
